# HomeHero — single-domain reverse proxy with automatic HTTPS (Caddy v2).
# Routes the API + Socket.IO to the gateway and everything else to the
# frontend SSR server. Set your domain via the DOMAIN env var, then:
#   DOMAIN=app.homehero.com caddy run --config deploy/Caddyfile
# (or replace {$DOMAIN} below with a literal domain).
#
# Topology (all on the same host here; split across hosts by changing targets):
#   /api/*, /socket.io/*  -> gateway        :4000
#   everything else        -> frontend SSR   :4174

{$DOMAIN} {
	encode zstd gzip

	# API + realtime → gateway (Caddy proxies WebSocket upgrades automatically)
	@api path /api/* /socket.io/*
	handle @api {
		reverse_proxy localhost:4000
	}

	# App (SSR + static assets) → frontend production server
	handle {
		reverse_proxy localhost:4174
	}
}
