# ── HomeHero backend environment ─────────────────────────────────────────────
# MySQL — Prisma uses DATABASE_URL (required)
DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/homehero

# Auth — use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-strong-secret

# Seed/admin bootstrap
ADMIN_EMAIL=admin@homehero.com
ADMIN_PASSWORD=ChangeMe123!

# Service ports
API_PORT=4001
AUTH_SERVICE_PORT=4101
PAYMENT_SERVICE_PORT=4102
BOOKING_SERVICE_PORT=4103
GATEWAY_PORT=4000

# CORS allow-list (comma-separated). REQUIRED in production — set to your
# frontend origin(s), e.g. https://app.homehero.com. Empty = blocked in prod.
ALLOWED_ORIGINS=http://localhost:8080

# Set NODE_ENV=production in prod to enforce the JWT_SECRET + CORS guards.
# NODE_ENV=production

# ── Hardening / scaling knobs ────────────────────────────────────────────────
# Proxy hops to trust for client IP (gateway + nginx = 1+). Affects rate limiting.
# TRUST_PROXY=1
# Max JSON request body. Default 1mb.
# JSON_BODY_LIMIT=1mb
# Rate limits — API: requests/min/IP. AUTH: login+signup+otp-verify per 15min/IP.
# OTP: otp-request per 15min per IP+phone (each can cost a real SMS).
# RATE_LIMIT_API=300
# RATE_LIMIT_AUTH=20
# RATE_LIMIT_OTP=5

# Gateway → service targets
AUTH_SERVICE_URL=http://localhost:4101
MONOLITH_URL=http://localhost:4001

# Optional but REQUIRED to run more than one API instance (PM2 cluster / multi-node).
# When set, REDIS_URL enables: BullMQ dispatch queue, the Socket.IO Redis adapter
# (realtime events fan out across all instances), and shared response caching.
# REDIS_URL=redis://localhost:6379

# ── Providers (each activates only when its keys are set; mock fallback otherwise) ──
# Payments — Razorpay (INR). Set both to go live.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# SMS OTP — choose ONE. MSG91 (India) is preferred; Twilio is the fallback.
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=
# MSG91_OTP_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1xxxxxxxxxx
# Push — Firebase Cloud Messaging. Provide the service-account JSON (one line).
# Requires firebase-admin (installed as an optional dependency).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
